{
  "name": "sticky-assistant",
  "version": "1.0.0",
  "description": "A multi-tool Google Workspace add-on suite for Sticky.",
  "main": "index.js",
  "scripts": {
    "build": "rollup -c rollup.config.mjs && shx cp appsscript.json dist/",
    "test": "vitest run",
    "push": "npm run build && clasp push",
    "watch": "rollup -c rollup.config.mjs -w",
    "lint": "tsc --noEmit && eslint --ext .ts src/",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "clean": "shx rm -rf dist/ node_modules/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RubenBroere/sticky-assistant.git"
  },
  "keywords": [],
  "author": "sticky@rubenbroere.com",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/RubenBroere/sticky-assistant/issues"
  },
  "homepage": "https://github.com/RubenBroere/sticky-assistant#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@gas-plugin/unplugin": "^0.1.2",
    "@google/clasp": "^3.3.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/google-apps-script": "^2.0.8",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "rollup": "^4.60.4",
    "shx": "^0.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
